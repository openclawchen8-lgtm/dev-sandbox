FROM python:3.12-slim

# 直接把色彩與工作目錄寫死在映像檔內
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV FORCE_COLOR=1

# 更新 Debian 套件清單並安裝基礎工具與 Python 環境
# Debian-slim 預設極簡，我們補上 Git、Curl、Python 3 及其套件管理器
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    git \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    ca-certificates \
    tzdata \
    gh \
    && rm -rf /var/lib/apt/lists/*

## debian method
#RUN apt-get update && apt-get install -y --no-install-recommends \
#    nodejs/stable \
#    && rm -rf /var/lib/apt/lists/*

# node official method
# https://github.com/cli/cli/blob/trunk/docs/install_linux.md#debian
# node version: v24.15.0
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && node -v

# 安裝 google/gemini-cli
RUN npm install -g @google/gemini-cli

# 🌟 關鍵環境變數：告訴 Debian 容器全域允許 pip 直接裝在系統，不報 externally-managed 錯誤
ENV PIP_BREAK_SYSTEM_PACKAGES=1

# 直接把依賴裝在系統 tw-quant-selector requirements.txt
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# 設定台灣時區（確保 Data Sources 排程擷取與 TWSE/TPEX 時間同步）
ENV TZ=Asia/Taipei

# 設定工作目錄
RUN mkdir -p /Users/claw
WORKDIR /Users/claw

